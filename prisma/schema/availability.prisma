model Availability {
  id String @id @default(uuid())

  technicianId String
  technician   TechnicianProfile @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  date DateTime // e.g. 2026-07-15

  startTime DateTime // e.g. 2026-07-15 09:00
  endTime   DateTime // e.g. 2026-07-15 12:00

  isBooked Boolean @default(false)
  bookings Booking?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([technicianId, date])
  @@map("availabilities")
  
}
