model Booking {
  id String @id @default(uuid())

  customerId String
  customer   User   @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Cascade)

  technicianId String
  technician   TechnicianProfile @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  availabilityId String @unique
  availability   Availability @relation(fields: [availabilityId], references: [id], onDelete  : Restrict) 

  price Decimal @db.Decimal(10, 2)

  status BookingStatus @default(REQUESTED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  payments  Payment?
  reviews   Review?

  @@index([customerId])
  @@index([technicianId])
  @@index([serviceId])
  @@index([availabilityId])
  @@map("bookings")
}
