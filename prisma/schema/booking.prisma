model Booking {
  id             String            @id @default(uuid())
  customerId     String
  technicianId   String
  serviceId      String
  price          Decimal           @db.Decimal(10, 2)
  status         BookingStatus     @default(REQUESTED)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  availabilityId String            @unique
  availability   Availability      @relation(fields: [availabilityId], references: [id])
  customer       User              @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Cascade)
  service        Service           @relation(fields: [serviceId], references: [id])
  technician     TechnicianProfile @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  payments       Payment?
  reviews        Review?

  @@index([customerId])
  @@index([technicianId])
  @@index([serviceId])
  @@index([availabilityId])
  @@map("bookings")
}
